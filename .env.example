NODE_ENV=development
API_PORT=4000
WEB_PORT=5173
CORS_ORIGIN=http://localhost:5173

# Database (Prisma)
# - Local dev: keep the localhost URLs and run Postgres via `docker compose up -d db`
# - Supabase cloud: replace both values with your Supabase Postgres connection strings
#   Supabase Dashboard -> Project Settings -> Database -> Connection string
#   Recommended:
#   - DATABASE_URL = pooled (PgBouncer) connection string for runtime/serverless
#   - DIRECT_URL   = direct (port 5432) connection string for Prisma migrations
#   If using the Supabase pooler with Prisma, you may need `pgbouncer=true` in the pooled URL query params.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ucc_pmp_rebuild?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/ucc_pmp_rebuild?schema=public
JWT_SECRET=replace-with-a-long-random-secret
STORAGE_MODE=local
UPLOAD_BASE_URL=http://localhost:4000

# Supabase Storage (uploads)
# Only required when STORAGE_MODE=supabase.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=ucc-pmp-files

# Frontend (Vite)
VITE_API_BASE_URL=http://localhost:4000/api
