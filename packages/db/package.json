{
  "name": "@ucc/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "prebuild": "node scripts/prisma-generate.cjs",
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "node ../../scripts/db-prisma.mjs generate --schema prisma/schema.prisma",
    "prisma:migrate:dev": "node ../../scripts/db-prisma.mjs migrate dev --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "node ../../scripts/db-prisma.mjs migrate deploy --schema prisma/schema.prisma",
    "prisma:migrate:status": "node ../../scripts/db-prisma.mjs migrate status --schema prisma/schema.prisma",
    "prisma:seed": "node ../../scripts/db-seed.mjs"
  },
  "dependencies": {
    "@prisma/client": "6.19.2",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "prisma": "6.19.2"
  }
}
